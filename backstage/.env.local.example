# Environment Configuration Template for Backstage Plugins
# Copy this to .env.local in your Backstage app root and fill in the values

# ============================================
# GitHub Integration
# ============================================
# Get these from https://github.com/settings/developers
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_CLIENT_ID=your_oauth_client_id
GITHUB_CLIENT_SECRET=your_oauth_client_secret

# ============================================
# Database Configuration
# ============================================
# For PostgreSQL (recommended for production)
DB_HOST=localhost
DB_PORT=5432
DB_USER=backstage
DB_PASSWORD=your_secure_password
DB_NAME=backstage

# For SQLite (local development only)
# DB_TYPE=sqlite
# DB_SQLITE_PATH=:memory:

# ============================================
# AWS Integration
# ============================================
# AWS region for default operations
AWS_REGION=your-aws-region

# IAM role ARN for Backstage to assume
# Format: arn:aws:iam::ACCOUNT_ID:role/backstage-role
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/backstage-role

# External ID for the IAM role (if configured)
AWS_EXTERNAL_ID=your_external_id_here

# AWS Account ID for cost analysis
AWS_ACCOUNT_ID=123456789012

# ============================================
# Kubernetes Integration
# ============================================
# Kubernetes cluster API URL
KUBERNETES_API_URL=https://your-k8s-cluster-url:6443

# Kubernetes authentication provider (serviceAccount, oidc, etc.)
KUBERNETES_AUTH_PROVIDER=serviceAccount

# Optional: Path to kubeconfig file
# KUBECONFIG=/path/to/kubeconfig

# Optional: Certificate Authority for K8s cluster
# KUBERNETES_CA_FILE=/path/to/ca.crt

# ============================================
# Jenkins Integration
# ============================================
# Jenkins server URL
JENKINS_URL=http://your-jenkins-url:8080

# Jenkins username for API access
JENKINS_USERNAME=jenkins_user

# Jenkins API token (generate in Jenkins UI)
JENKINS_TOKEN=jenkins_api_token_here

# ============================================
# Terraform Integration
# ============================================
# Terraform Registry details (if using private registry)
TERRAFORM_REGISTRY_HOSTNAME=registry.terraform.io
TERRAFORM_REGISTRY_TOKEN=your_terraform_token_here

# ============================================
# Backstage Core Settings
# ============================================
# Backend base URL
BACKEND_URL=http://localhost:7007

# Frontend base URL
APP_URL=http://localhost:3000

# ============================================
# Optional: GitHub Enterprise or Custom GitHub
# ============================================
# If using GitHub Enterprise, set these:
# GITHUB_ENTERPRISE_URL=https://your-github-enterprise.com
# GITHUB_ENTERPRISE_API_URL=https://your-github-enterprise.com/api/v3

# ============================================
# Optional: CI/CD Integration
# ============================================
# For GitHub Actions integration
# GITHUB_WEBHOOK_SECRET=your_webhook_secret
# GITHUB_APP_ID=your_app_id
# GITHUB_APP_PRIVATE_KEY=your_private_key_content

# ============================================
# Optional: Cost And Management
# ============================================
# If using AWS Cost Explorer
# AWS_COST_EXPLORER_ENABLED=true
# AWS_COST_EXPLORER_API_REGION=your-aws-region

# ============================================
# Optional: Logging and Debugging
# ============================================
# Set to true for verbose logging
DEBUG=false
LOG_LEVEL=info

# ============================================
# Optional: Observability
# ============================================
PROMETHEUS_PORT=9090
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8081
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# ============================================
# Notes for WSL Users
# ============================================
# 1. For localhost access from Windows, use the WSL IP:
#    Instead of http://localhost:3000, use:
#    http://$(hostname -I | awk '{print $1}'):3000
#
# 2. If you need to access services from Windows host:
#    - Get WSL IP: hostname -I (in WSL terminal)
#    - Update URLs to use that IP instead of localhost
#
# 3. For file paths in WSL:
#    - Use /mnt/c/ to access Windows C: drive
#    - Example: /mnt/c/Users/tukue/terraform-jenkins-aws
#
# ============================================
