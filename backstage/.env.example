# Docker Compose environment values for Backstage
# Copy this file to `.env` before running `docker compose up -d`.

# Backstage image
BACKSTAGE_IMAGE=ghcr.io/backstage/community-all-in-one:latest

# Backstage URLs and ports
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:7007
BACKSTAGE_PORT=3000
BACKSTAGE_BACKEND_PORT=7007

# PostgreSQL settings
POSTGRES_PORT=5432
DB_HOST=postgres
DB_PORT=5432
DB_NAME=backstage
DB_USER=backstage
DB_PASSWORD=change-me

# GitHub
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AWS (optional)
AWS_REGION=us-east-1
AWS_ROLE_ARN=
AWS_EXTERNAL_ID=

# Jenkins (optional)
JENKINS_URL=
JENKINS_USERNAME=
JENKINS_TOKEN=

# Runtime mode
NODE_ENV=production
