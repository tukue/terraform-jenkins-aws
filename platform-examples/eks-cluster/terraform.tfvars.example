aws_region              = "eu-north-1"
aws_account_id          = "123456789012"
cluster_name            = "my-platform"
environment             = "dev"
kubernetes_version      = "1.31"
authentication_mode     = "API_AND_CONFIG_MAP"
enable_lb_controller    = true

tags = {
  Environment = "dev"
  Owner       = "platform-team"
  Tier        = "nonprod"
}
