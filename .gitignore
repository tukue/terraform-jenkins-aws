# Ignore Terraform state files
*.tfstate
*.tfstate.backup
.terraformvars

# Ignore crash logs
crash.log

# Ignore Terraform variable files (if they contain sensitive data)
*.tfvars
*.tfvars.json
!terraform.dev.tfvars
!terraform.qa.tfvars
!terraform.prod.tfvars
!terraform.vault.tfvars
!terraform.vault-local.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore .terraform directory
.terraform/

# Ignore local environment files
.terraform.lock.hcl

# Ignore remote backend configuration files
remote_backend_s3.tf    

# Ignore backend configuration files
backend-config-*.
