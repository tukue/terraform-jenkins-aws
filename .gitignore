# Ignore Terraform state files
*.tfstate
*.tfstate.backup
.terraformvars

# Ignore crash logs
crash.log

# Ignore Terraform variable files (if they contain sensitive data)
*.tfvars
*.tfvars.json
!terraform.dev.tfvars
!terraform.qa.tfvars
!terraform.prod.tfvars
!terraform.tfvars.example
!terraform.vault-local.tfvars.example

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore .terraform directory
.terraform/

# Keep .terraform.lock.hcl committed for reproducible provider selections.

# Ignore remote backend configuration files
remote_backend_s3.tf    

# Ignore backend configuration files
backend-config-*.

# Local environment variables
.env
