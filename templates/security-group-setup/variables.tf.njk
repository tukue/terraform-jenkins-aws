variable "aws_region" {
  description = "AWS region where the security group is managed"
  type        = string
  default     = "{{ aws_region }}"
}

variable "aws_account_id" {
  description = "AWS account ID expected for this security group"
  type        = string
  default     = "{{ aws_account_id }}"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "{{ environment }}"
}

variable "owner" {
  description = "Owning team or contact"
  type        = string
  default     = "{{ owner }}"
}

variable "project" {
  description = "Project or service name"
  type        = string
  default     = "{{ project }}"
}

variable "cost_center" {
  description = "Cost allocation tag"
  type        = string
  default     = "{{ cost_center }}"
}
