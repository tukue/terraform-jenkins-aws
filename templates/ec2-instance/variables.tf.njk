variable "name" {
  description = "EC2 instance name"
  type        = string
  default     = "{{ name }}"
}

variable "ami_id" {
  description = "AMI ID for the EC2 instance"
  type        = string
  default     = "{{ ami_id }}"
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "{{ instance_type }}"
}

variable "subnet_id" {
  description = "Subnet ID where the instance will be launched"
  type        = string
  default     = "{{ subnet_id }}"
}

variable "vpc_security_group_ids" {
  description = "List of security group IDs to attach"
  type        = list(string)
  default     = {{ security_group_ids | dump }}
}

variable "key_name" {
  description = "EC2 key pair name for SSH access"
  type        = string
  default     = "{{ key_name }}"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "{{ environment }}"
}

variable "owner" {
  description = "Owning team or contact"
  type        = string
  default     = "{{ owner }}"
}

variable "project" {
  description = "Project or service name"
  type        = string
  default     = "{{ project }}"
}

variable "cost_center" {
  description = "Cost allocation tag"
  type        = string
  default     = "{{ cost_center }}"
}

variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "eu-north-1"
}
