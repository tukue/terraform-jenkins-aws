module "customer_runtime" {
  source = "../../platform-modules/customer-ecs-runtime"

  customer_name       = "${{ values.customer_name }}"
  tenant_name         = "${{ values.tenant_name }}"
  environment         = "${{ values.environment }}"
  aws_region          = "${{ values.aws_region }}"
  aws_account_id      = "${{ values.aws_account_id }}"
  container_image     = "${{ values.container_image }}"
  container_port      = ${{ values.container_port }}
  desired_count       = ${{ values.desired_count }}
  cpu                 = ${{ values.cpu }}
  memory              = ${{ values.memory }}
  alb_certificate_arn = "${{ values.alb_certificate_arn }}"
  hosted_zone_id      = "${{ values.hosted_zone_id }}"
  dns_name            = "${{ values.dns_name }}"
}
