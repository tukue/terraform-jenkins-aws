terraform {
  required_version = ">= 1.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region              = "${{ values.aws_region }}"
  allowed_account_ids = ["${{ values.aws_account_id }}"]
  {% if values.aws_profile %}
  profile = "${{ values.aws_profile }}"
  {% endif %}
}
