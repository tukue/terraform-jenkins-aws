terraform {
  required_version = ">= 1.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

provider "aws" {
  region              = "${{ values.aws_region }}"
  profile             = ${{ values.aws_profile | dump }}
  allowed_account_ids = ["${{ values.aws_account_id }}"]
}
